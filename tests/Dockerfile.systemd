# Systemd-enabled container for testing kiro-gateway user-level installer
FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
ENV container=docker

# Install systemd + python + tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    systemd systemd-sysv dbus \
    python3 python3-venv python3-pip \
    curl git ca-certificates \
    && pip3 install pytest --break-system-packages \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Remove unnecessary systemd units
RUN rm -f /lib/systemd/system/multi-user.target.wants/* \
    /etc/systemd/system/*.wants/* \
    /lib/systemd/system/local-fs.target.wants/* \
    /lib/systemd/system/sockets.target.wants/*udev* \
    /lib/systemd/system/sockets.target.wants/*initctl* \
    /lib/systemd/system/sysinit.target.wants/systemd-tmpfiles-setup* \
    /lib/systemd/system/systemd-update-utmp*

# Create a test user (non-root) for user-level systemd
RUN useradd -m -s /bin/bash testuser \
    && loginctl enable-linger testuser 2>/dev/null || true

# Copy project
COPY . /workspace
RUN chown -R testuser:testuser /workspace

VOLUME ["/sys/fs/cgroup"]
STOPSIGNAL SIGRTMIN+3

CMD ["/lib/systemd/systemd"]
